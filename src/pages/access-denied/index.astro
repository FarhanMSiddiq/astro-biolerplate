---
import { FcUnlock } from "react-icons/fc";
import Layout from "../../layouts/Layout.astro";
---

<Layout>
  <div
    class="flex justify-center items-center min-h-screen bg-gradient-to-r from-blue-400 to-blue-600"
  >
    <div class="text-center p-6 bg-white shadow-lg rounded-lg">
      <h2 class="text-2xl text-red-600 font-bold text-center">Access Denied</h2>
      <div class="flex justify-center mb-4">
        <FcUnlock className="text-6xl text-blue-600" />
      </div>
      <p class="text-gray-700 mb-6">
        You do not have permission to access this page.
      </p>
      <a
        href="/"
        class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded"
      >
        Go Back
      </a>
    </div>
  </div>
</Layout>
