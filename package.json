{
  "name": "astro-template",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "start": "astro preview --port 4321 --host 0.0.0.0",
    "migration:create": "sh -c 'npx typeorm migration:create ./src/database/migrations/$1' --",
    "migration:build": "tsc --project tsconfig.db.json",
    "migration:run": "npx typeorm migration:run -d ./dist/database/data-source.js",
    "migration:rollback": "npx typeorm migration:revert -d ./dist/database/data-source.js",
    "migration:build-run": "tsc --project tsconfig.db.json && npx typeorm migration:run -d ./dist/database/data-source.js"
  },
  "dependencies": {
    "@astrojs/netlify": "^7.0.6",
    "@astrojs/node": "^9.1.0",
    "@astrojs/react": "4.2.0",
    "@astrojs/renderer-react": "0.5.0",
    "@astrojs/tailwind": "6.0.0",
    "@nanostores/react": "0.8.4",
    "@types/bcryptjs": "2.4.6",
    "@types/react-dom": "19.0.3",
    "astro": "5.2.5",
    "axios": "1.7.9",
    "dotenv": "16.4.7",
    "nanostores": "0.11.4",
    "react": "19.0.0",
    "react-daisyui": "5.0.5",
    "react-dom": "19.0.0",
    "react-icons": "5.4.0",
    "react-select": "5.10.0",
    "reflect-metadata": "0.2.2",
    "sweetalert2": "11.16.1",
    "typeorm": "0.3.20",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@astrojs/ts-plugin": "1.10.4",
    "@eslint/js": "9.20.0",
    "@types/js-cookie": "3.0.6",
    "@types/pg": "8.11.11",
    "@types/react": "19.0.8",
    "autoprefixer": "10.4.20",
    "bcryptjs": "3.0.0",
    "daisyui": "4.12.10",
    "eslint": "9.20.1",
    "eslint-plugin-react": "7.37.4",
    "globals": "15.15.0",
    "js-cookie": "3.0.5",
    "pg": "8.13.1",
    "postcss": "8.5.1",
    "prettier": "3.5.0",
    "prettier-plugin-astro": "0.14.1",
    "tailwindcss": "3.4.17",
    "typescript": "6.0.2",
    "typescript-eslint": "8.24.1"
  }
}
