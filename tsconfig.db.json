{
    "compilerOptions": {
      "outDir": "./dist/database",
      "module": "CommonJS",
      "target": "ES6",
      "esModuleInterop": true,
      "skipLibCheck": true,
    },
    "include": [
      "src/database/migrations/*",
      "src/database/data-source.ts"
    ],
    "exclude": ["node_modules", "dist"],
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
  }
  